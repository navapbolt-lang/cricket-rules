# ──────────────────────────────────────────
# Cricket Rules AI — Production Environment
# ──────────────────────────────────────────
# Copy this to .env and fill in your values
# cp deployment.env.example .env

# ── LLM (Gemini) ──
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-1.5-pro
EMBEDDING_MODEL=models/text-embedding-004

# ── Vector DB ──
# In Docker Compose: http://qdrant:6333
# Local dev: http://localhost:6333
VECTOR_DB_TYPE=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ── Databases ──
# In Docker Compose:
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/cricket_rules
REDIS_URL=redis://redis:6379

# ── Auth ──
ADMIN_API_KEY=change-this-to-a-random-64-char-string
JWT_SECRET=change-this-to-another-random-64-char-string

# ── Partner Defaults ──
DEFAULT_PLAN=starter
DEFAULT_MONTHLY_QUOTA=10000

# ── Re-ranker ──
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu

# ── Logging ──
LOG_LEVEL=INFO

# ── Domain (nginx) ──
DOMAIN_NAME=cricketrules.ai
ADMIN_EMAIL=admin@cricketrules.ai
