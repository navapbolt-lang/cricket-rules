# ── LLM Provider (Groq) ──
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEYS=  # Comma-separated fallback keys

# ── LLM Provider (Gemini fallback) ──
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEYS=  # Comma-separated fallback keys

# ── Web Search (SerpAPI) ──
SERPAPI_KEY=your_serpapi_key_here
SERPAPI_KEYS=  # Comma-separated fallback keys
WEB_SEARCH_ENABLED=true

# ── LLM Config ──
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Vector Database (Qdrant Cloud) ──
VECTOR_DB_TYPE=qdrant
QDRANT_URL=https://your-cluster.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# ── Auth ──
ADMIN_API_KEY=your_admin_secret_key_here
JWT_SECRET=your_jwt_secret_here

# ── Partner Defaults ──
DEFAULT_PLAN=starter
DEFAULT_MONTHLY_QUOTA=10000

# ── Re-ranker ──
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_DEVICE=cpu

# ── Logging ──
LOG_LEVEL=INFO
